{
  "manifest_version": 3,
  "name": "Amazon FBA Margin & Stock Tracker",
  "version": "1.0.0",
  "description": "Calcule la marge réelle et espionne les stocks concurrents sur Amazon.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.amazon.fr/*",
    "*://*.amazon.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Ouvrir le calculateur"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.fr/*",
        "*://*.amazon.com/*"
      ],
      "js": [
        "scripts/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}